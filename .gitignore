# ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ──────────────────────────────────────────────────────
# SonarQube scanner
# ──────────────────────────────────────────────────────
.sonar/
.scannerwork/

